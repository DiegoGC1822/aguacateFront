{
  "expo": {
    "name": "aguacateFront",
    "slug": "aguacateFront",
    "scheme": "aguacatefront",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/paltaReal.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/paltaReal.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/paltaReal.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.diegogc1822.aguacateFront"
    },
    "web": {
      "favicon": "./assets/paltaReal.png"
    },
    "plugins": ["expo-router", "expo-font"],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dfc7c786-62dd-4285-a1f6-3fc5f66611bb"
      }
    }
  }
}
